# Postgres connection string (Prisma)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Admin PIN gate on /admin (existing)
ADMIN_PIN=1234

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxx

# Random secret shared between vercel.json cron and the cron route
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-me

# Email config for daily export
EXPORT_RECIPIENT=vendor@logistarinc.com
EXPORT_FROM=timesheet@logistarinc.com
